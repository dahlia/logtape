{
  "name": "@logtape/testing",
  "version": "2.2.0",
  "license": "MIT",
  "exports": "./src/mod.ts",
  "tasks": {
    "build": "pnpm build",
    "test": "deno test",
    "test:node": {
      "dependencies": [
        "build"
      ],
      "command": "node --experimental-transform-types --test"
    },
    "test:bun": {
      "dependencies": [
        "build"
      ],
      "command": "bun test"
    },
    "test-all": {
      "dependencies": [
        "test",
        "test:node",
        "test:bun"
      ]
    }
  }
}
